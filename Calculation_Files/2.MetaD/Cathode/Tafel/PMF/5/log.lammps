pair_coeff * *

# 固定原子受力、速度为 0
group fixed id 1:168
168 atoms in group fixed
group mobile subtract all fixed
171 atoms in group mobile
fix freeze_fixed fixed setforce 0.0 0.0 0.0
velocity fixed set 0 0 0

# 在z=27处添加硬性反射墙
fix wall1 mobile wall/reflect zhi 26

# 计算mobile组的温度
compute mTemp mobile temp
thermo 50
thermo_style custom step temp c_mTemp pe ke etotal press
velocity mobile  create 298.15 12345 mom yes rot yes

#fix ensemble mobile  nvt temp 298.15 298.15 1
#timestep 0.0005
#run 15000
#unfix ensemble        # 结束预平衡的NVT

fix ensemble mobile  nvt temp 298.15 298.15 1
fix meta  all colvars pmf.in tstat ensemble
timestep 0.0005
dump trace all custom 10 md.lammpstrj id type x y z
run 200000

